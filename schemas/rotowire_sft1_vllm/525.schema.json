```sql
SELECT 
  'Kings' AS team,
  COUNT(CASE WHEN team_name = 'Kings' THEN 1 ELSE NULL END) AS wins,
  COUNT(CASE WHEN team_name = 'Kings' THEN 1 ELSE NULL END) AS losses
FROM 
  games
UNION ALL
SELECT 
  'Timberwolves' AS team,
  COUNT(CASE WHEN team_name = 'Timberwolves' THEN 1 ELSE NULL END) AS wins,
  COUNT(CASE WHEN team_name = 'Timberwolves' THEN 1 ELSE NULL END) AS losses
FROM 
  games
UNION ALL
SELECT 
  'Kings at home' AS team,
  COUNT(CASE WHEN team_name = 'Kings' AND location = 'home' THEN 1 ELSE NULL END) AS wins,
  COUNT(CASE WHEN team_name = 'Kings' AND location = 'home' THEN 1 ELSE NULL END) AS losses
FROM 
  games
UNION ALL
SELECT 
  'Timberwolves at home' AS team,
  COUNT(CASE WHEN team_name = 'Timberwolves' AND location = 'home' THEN 1 ELSE NULL END) AS wins,
  COUNT(CASE WHEN team_name = 'Timberwolves' AND location = 'home' THEN 1 ELSE NULL END) AS losses
FROM 
  games;
